# Enable RewriteEngine
RewriteEngine On

# --- Rules to remove extensions (internal rewrite) ---

# For .php files: rewrite requests without extension to .php
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# For .html files: rewrite requests without extension to .html
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# --- Optional: Redirect requests FROM .php/.html TO clean URLs (good for SEO) ---

# Redirect .php to clean URL (e.g., example.com/page.php -> example.com/page)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# Redirect .html to clean URL (e.g., example.com/page.html -> example.com/page)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]